# Token de Discord Bot
# Obtenerlo en: https://discord.com/developers/applications
DISCORD_TOKEN=tu_token_de_discord_aqui

# IDs de usuarios autorizados (separados por comas)
# Para obtener: Modo Desarrollador en Discord > Click derecho en usuario > Copiar ID
AUTHORIZED_USERS=123456789012345678

# Workspace path
WORKSPACE_PATH=/workspace