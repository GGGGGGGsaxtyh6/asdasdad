# Token de tu bot de Discord (obtenlo en https://discord.com/developers/applications)
DISCORD_TOKEN=tu_token_aqui

# ID de usuario(s) de Discord autorizados para usar el bot (separados por comas)
# Para obtener tu ID: Activa el Modo Desarrollador en Discord > Click derecho en tu usuario > Copiar ID
AUTHORIZED_USERS=123456789012345678,987654321098765432

# Prefijo de comandos (opcional)
COMMAND_PREFIX=!cursor