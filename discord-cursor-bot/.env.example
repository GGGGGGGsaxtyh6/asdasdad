# Token de tu bot de Discord (obtenlo en https://discord.com/developers/applications)
DISCORD_TOKEN=tu_token_de_discord_aqui

# API Key de Anthropic Claude (obtenla en https://console.anthropic.com/)
ANTHROPIC_API_KEY=tu_api_key_de_anthropic_aqui

# ID de usuario(s) de Discord autorizados para usar el bot (separados por comas)
# Para obtener tu ID: Activa el Modo Desarrollador en Discord > Click derecho en tu usuario > Copiar ID
AUTHORIZED_USERS=123456789012345678

# Modelo de Claude a usar
CLAUDE_MODEL=claude-sonnet-4-20250514

# Workspace path
WORKSPACE_PATH=/workspace