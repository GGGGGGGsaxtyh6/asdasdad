from Crypto.Util.number import long_to_bytes

n = 

c1 = 

c2 = 

e = 3

# Franklin-Reiter Related Message Attack
# m1 = flag||r1, m2 = flag||r2
# In integer: m = M * 2^128 + r

B = 2^128

# Coppersmith method to find M
P.<x> = PolynomialRing(Zmod(n))

# We want to find M such that (M*B + x)^3 - c1 has a small root x < B
f1 = (x)^3 - c1

# Use small_roots to find m1 directly (if m1^3 hasn't wrapped around n much)
# Actually, since e=3 and n is 2048 bits, messages up to ~682 bits could work

# Try different approaches
print("Trying Coppersmith's method...")

# Approach 1: Find m1 directly
f = x^3 - c1
roots = f.small_roots(X=2^700, beta=1.0)
if roots:
    m1 = int(roots[0])
    flag = long_to_bytes(m1)[:-16]
    print(f"Flag from c1: {flag}")
    
f = x^3 - c2  
roots = f.small_roots(X=2^700, beta=1.0)
if roots:
    m2 = int(roots[0])
    flag = long_to_bytes(m2)[:-16]
    print(f"Flag from c2: {flag}")

