
from Crypto.Util.number import long_to_bytes

n = 
c1 = 
c2 = 
e = 3

print("Running in SageMath...")
print()

# Method 1: Direct small_roots
P.<x> = PolynomialRing(Zmod(n))

print("Method 1: Trying small_roots on x^3 - c...")
f1 = x^3 - c1
try:
    roots1 = f1.small_roots(X=2^700, beta=1.0, epsilon=1/30)
    if roots1:
        m1 = int(roots1[0])
        print(f"Found m1 = {m1}")
        msg = long_to_bytes(m1)
        print(f"Message: {msg}")
        flag = msg[:-16]
        print(f"FLAG: {flag}")
except Exception as e:
    print(f"Method 1 failed: {e}")

print()

# Method 2: Franklin-Reiter for related messages
print("Method 2: Franklin-Reiter attack...")

# Both messages are: flag || 16_random_bytes
# m = flag_int * 256^16 + random_int

B = 256^16

# Try to find the common part using polynomial GCD
# We need to find delta such that gcd(x^3 - c1, (x-delta)^3 - c2) gives us (x-m1)

print("Searching for delta...")

def test_delta(delta):
    P1 = x^3 - c1
    P2 = (x - delta)^3 - c2
    g = gcd(P1, P2)
    if g.degree() == 1:
        # Linear polynomial, extract root
        coeffs = g.list()
        if len(coeffs) >= 2 and coeffs[1] != 0:
            root = -coeffs[0] / coeffs[1]
            root = int(root)
            # Verify
            if pow(root, 3, n) == c1:
                return root
    return None

# Try systematic delta search
for k in range(-10000, 10001):
    if k % 1000 == 0:
        print(f"Trying k = {k}...")
    
    delta = k
    result = test_delta(delta)
    if result:
        print(f"\nFOUND with delta = {delta}!")
        m1 = result
        print(f"m1 = {m1}")
        msg = long_to_bytes(m1)
        print(f"Message: {msg}")
        flag = msg[:-16]
        print(f"\nFLAG: {flag}")
        break

print("Done.")
